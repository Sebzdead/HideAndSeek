---
import Layout from "@/layouts/Layout.astro";
import { CuratorMap } from "@/components/CuratorMap";
import fs from "fs";
import path from "path";

// Read the raw datasets at build/dev time
const resourcesDir = path.join(process.cwd(), "Resources");

let montrealData = { type: "FeatureCollection", features: [] };

try {
    const montrealPath = path.join(resourcesDir, "Montreal.geojson");
    if (fs.existsSync(montrealPath)) {
        montrealData = JSON.parse(fs.readFileSync(montrealPath, "utf-8"));
    }
} catch (e) {
    console.error("Could not read Montreal data", e);
}
---

<Layout className="bg-white">
    <main class="w-full h-screen">
        <CuratorMap 
            client:only="react" 
            montrealData={montrealData} 
        />
    </main>
</Layout>
